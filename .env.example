# job-hunting-radar 비밀 환경변수 템플릿.
# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (.env 는 .gitignore 되어 커밋 안 됨)
#   cp .env.example .env
# ⚠️ 실제 토큰/키는 절대 커밋하지 마세요.

# 크롤 대상 채용 플랫폼 (필수). 코드엔 대상명을 두지 않고 여기서만 주입한다.
#   PLATFORM_NAME     : 노트·대시보드·텔레그램에 표시할 플랫폼 이름 (미설정 시 "채용 플랫폼")
#   PLATFORM_API_BASE : 목록/상세 API 베이스 URL (예: https://api.example.com)
#   PLATFORM_SITE_BASE: 공고 상세 페이지 베이스 URL (예: https://example.com)
PLATFORM_NAME=
PLATFORM_API_BASE=
PLATFORM_SITE_BASE=

# (선택) 2번째 소스. config.json의 sources[]에서 type "platform_b"를 enabled 하면 사용.
#   PLATFORM_B_NAME     : 노트·대시보드에 표시할 이름 (미설정 시 "소스B")
#   PLATFORM_B_API_BASE : 목록/상세 API 베이스
#   PLATFORM_B_SITE_BASE: 공고 상세 페이지 베이스
# PLATFORM_B_NAME=
# PLATFORM_B_API_BASE=
# PLATFORM_B_SITE_BASE=

# 텔레그램 봇 토큰 (@BotFather 발급). 텔레그램 알림 쓸 때 필수.
TELEGRAM_BOT_TOKEN=

# (선택) chat_id. 비우면 config.notify.telegram.chat_id 값을 사용.
# TELEGRAM_CHAT_ID=

# (선택) llm.provider="api" 일 때만 필요. Claude Code 구독(claude_cli) 쓰면 불필요.
# ANTHROPIC_API_KEY=
